{
  // Cloudflare Workers (static assets) — same setup as wodnepatenty
  "name": "patentnapodroz",
  "compatibility_date": "2026-07-01",
  "assets": {
    "directory": "./dist",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page"
  },
  "build": {
    "command": "node build.js"
  }
}
